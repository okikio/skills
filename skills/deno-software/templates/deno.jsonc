{
  "name": "@scope/package",
  "version": "0.1.0",
  "exports": "./src/mod.ts",
  "imports": {
    "@std/assert": "jsr:@std/assert@^1.0.0",
    "zod": "npm:zod@^4.0.0"
  },
  "tasks": {
    "check": "deno fmt --check && deno lint && deno check src/mod.ts && deno test",
    "test": "deno test",
    "test:watch": "deno test --watch"
  },
  "compilerOptions": {
    "strict": true
  },
  "fmt": {
    "lineWidth": 100
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
