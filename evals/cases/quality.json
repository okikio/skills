      "shouldActivate": true,
      "id": "hq-deno-workspace-protocol",
      "title": "Reject workspace protocol in deno imports",
      "skill": "deno-software",
      "kind": "knowledge",
      "split": "valid-unseen",
      "prompt": "A hybrid monorepo puts @acme/core: workspace:* inside deno.json imports. Decide whether it is valid, identify the correct owning manifest and field, and give a command-level verification plan without inventing repository files.",
      "assertions": [
        {
          "kind": "regex",
          "value": "package\\.json[\\s\\S]*(dependencies|devDependencies)"
        },
        {
          "kind": "not-contains",
          "value": "deno.json imports supports workspace:*"
        },
        {
          "kind": "regex",
          "value": "(inspect|verify|check|run)"
        }
      ],
      "rubric": [
        "Distinguishes Deno workspace identity from npm workspace protocols",
        "Does not prescribe deleting package.json",
        "Verification uses the repository's actual tasks"
      ],
      "tags": [
        "workspace",
        "imports"
      ],
      "rationale": "Tests a high-frequency Deno configuration hallucination."
    },
    {
      "requiredReferences": [],
      "forbiddenReferences": [],
      "shouldActivate": true,
      "id": "hq-deno-hybrid-astro",
      "title": "Classify a Deno-run Astro application",
      "skill": "deno-software",
      "kind": "trajectory",
      "split": "adversarial",
      "prompt": "An Astro app has package.json dependencies, package-lock.json, deno.json tasks, and CI invokes deno task build. Classify ownership without assuming Deno should replace npm metadata. Explain what evidence could change the classification and how to verify the real build.",
      "assertions": [
        {
          "kind": "regex",
          "value": "(package\\.json-first|hybrid)"
        },
        {
          "kind": "regex",
          "value": "Astro|framework"
        },
        {
          "kind": "regex",
          "value": "build"
        }
      ],
      "rubric": [
        "Classifies by durable ownership rather than executable",
        "Inspects framework and deployment contracts",
        "Preserves compatible npm metadata"
      ],
      "tags": [
        "astro",
        "hybrid"
      ],
      "rationale": "Prevents ideological Deno migration."
    },
    {
